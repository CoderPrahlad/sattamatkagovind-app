generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  name          String
  mobile        String   @unique
  password      String
  role          String   @default("user")
  balance       Float    @default(0)
  winningAmount Float    @default(0)
  referralCode  String   @unique
  referredBy    String?
  referrer      User?    @relation("Referral", fields: [referredBy], references: [id])
  referredUsers User[]   @relation("Referral")
  isActive            Boolean  @default(true)
  referralBonusClaimed Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt     DateTime @updatedAt

  bids           Bid[]
  transactions   WalletTransaction[]
  notifications  Notification[]
  tickets        SupportTicket[]
  bankDetail     BankDetail?

  @@index([role])
  @@index([isActive])
  @@index([referredBy])
  @@index([createdAt])
}

model Game {
  id          String   @id @default(cuid())
  name        String   @unique
  openTime    String
  closeTime   String
  isOpen      Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  results     GameResult[]
  bids        Bid[]
}

model GameResult {
  id        String   @id @default(cuid())
  gameId    String
  game      Game     @relation(fields: [gameId], references: [id])
  result    String
  date      String
  declaredAt DateTime @default(now())

  @@index([gameId, date])
  @@unique([gameId, date])
}

model Bid {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  gameId     String
  game       Game     @relation(fields: [gameId], references: [id])
  bidType    String
  number     String
  amount     Float
  status     String   @default("pending")
  winAmount  Float?
  targetDate String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId])
  @@index([gameId])
  @@index([status])
  @@index([gameId, targetDate])
  @@index([userId, status])
  @@index([userId, createdAt])
  @@index([targetDate, status])
}

model WalletTransaction {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String
  amount    Float
  status    String   @default("pending")
  upiNumber String?
  bankAccount String?
  bankName  String?
  ifscCode  String?
  accountHolder String?
  accountNumber String?
  upiId        String?
  utrNumber    String?
  screenshotUrl String?
  adminNote    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([type, status])
  @@index([createdAt])
  @@index([userId, status])
  @@index([userId, createdAt])
  @@index([status, createdAt])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  title     String
  message   String
  type      String   @default("info")
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([isRead])
  @@index([userId, isRead])
}

model Banner {
  id        String   @id @default(cuid())
  title     String
  subtitle  String?
  ctaText   String?
  ctaLink   String?
  isActive  Boolean  @default(true)
  imageUrl  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GameConfig {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

model BankDetail {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id])
  accountHolder   String?
  accountNumber   String?
  ifscCode        String?
  bankName        String?
  upiId           String?
  isDefault       Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model SupportTicket {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  subject   String
  message   String
  type      String   @default("general")
  status    String   @default("open")
  priority  String   @default("normal")
  adminReply String?
  replies   TicketReply[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

model TicketReply {
  id        String   @id @default(cuid())
  ticketId  String
  ticket    SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  message   String
  isAdmin   Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([ticketId])
  @@index([createdAt])
}

model OtpEntry {
  id        String   @id @default(cuid())
  mobile    String
  otp       String
  purpose   String   @default("sms")
  verified  Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([mobile, purpose])
}

// ─── NEW: APK Download Tracking ───────────────────────────
model AppDownload {
  id           String   @id @default(cuid())
  downloadedAt DateTime @default(now())
  ipAddress    String?
  source       String?  @default("external")

  @@index([downloadedAt])
}