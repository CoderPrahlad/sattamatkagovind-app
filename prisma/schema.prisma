generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  name          String
  mobile        String   @unique
  password      String
  role          String   @default("user")  // "user" or "admin"
  balance       Float    @default(0)
  winningAmount Float    @default(0)
  referralCode  String   @unique
  referredBy    String?
  referrer      User?    @relation("Referral", fields: [referredBy], references: [id])
  referredUsers User[]   @relation("Referral")
  isActive            Boolean  @default(true)
  referralBonusClaimed Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt     DateTime @updatedAt

  bids           Bid[]
  transactions   WalletTransaction[]
  notifications  Notification[]
  tickets        SupportTicket[]
  bankDetail     BankDetail?
}

model Game {
  id          String   @id @default(cuid())
  name        String   @unique  // Gali, Disawar, Ghaziabad, Faridabad, Kalyan
  openTime    String   // e.g. "09:00"
  closeTime   String   // e.g. "10:00"
  isOpen      Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  results     GameResult[]
  bids        Bid[]
}

model GameResult {
  id        String   @id @default(cuid())
  gameId    String
  game      Game     @relation(fields: [gameId], references: [id])
  result    String   // e.g. "5" or "23" or "100"
  date      String   // e.g. "2024-05-01"
  declaredAt DateTime @default(now())

  @@index([gameId, date])
  @@unique([gameId, date])
}

model Bid {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  gameId     String
  game       Game     @relation(fields: [gameId], references: [id])
  bidType    String   // "single" or "jodi"
  number     String   // selected number(s)
  amount     Float
  status     String   @default("pending")  // "pending", "won", "lost"
  winAmount  Float?
  targetDate String   // the date this bid is for (e.g. "2024-05-01"), allows next-day bidding
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId])
  @@index([gameId])
  @@index([status])
  @@index([gameId, targetDate])
  @@index([userId, status])
  @@index([userId, createdAt])
  @@index([targetDate, status])
}

model WalletTransaction {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String   // "deposit", "withdrawal", "bid", "win"
  amount    Float
  status    String   @default("pending")  // "pending", "approved", "rejected"
  upiNumber String?
  bankAccount String?
  bankName  String?
  ifscCode  String?
  accountHolder String?
  accountNumber String?
  upiId        String?
  utrNumber    String?
  screenshotUrl String?
  adminNote    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([type, status])
  @@index([createdAt])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  title     String
  message   String
  type      String   @default("info")  // "info", "success", "warning", "offer"
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
}

model Banner {
  id        String   @id @default(cuid())
  title     String
  subtitle  String?
  ctaText   String?
  ctaLink   String?
  isActive  Boolean  @default(true)
  imageUrl  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GameConfig {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

model BankDetail {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id])
  accountHolder   String?
  accountNumber   String?
  ifscCode        String?
  bankName        String?
  upiId           String?
  isDefault       Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model SupportTicket {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  subject   String
  message   String
  type      String   @default("general")
  status    String   @default("open")
  priority  String   @default("normal")
  adminReply String?
  replies   TicketReply[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

model TicketReply {
  id        String   @id @default(cuid())
  ticketId  String
  ticket    SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  message   String
  isAdmin   Boolean  @default(false)
  createdAt DateTime @default(now())
}
